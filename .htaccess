########################################
# BASIC SECURITY / OPTIONS
########################################
Options -Indexes

# Enable rewrite engine
RewriteEngine On

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php81” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php81 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

########################################
# CANONICAL DOMAIN + HTTPS + CLEAN URLS
########################################
<IfModule mod_rewrite.c>

  ########################################
  # Force HTTPS and www
  ########################################
  RewriteCond %{HTTP_HOST} !^www\.kristenbytes\.com$ [NC,OR]
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://www.kristenbytes.com%{REQUEST_URI} [L,R=301]

  ########################################
  # Redirect .php and .html to extensionless
  ########################################

  # Redirect .php to extensionless
  RewriteCond %{THE_REQUEST} \s/+(.+)\.php[\s?] [NC]
  RewriteRule ^ %1 [R=301,L]

  # Redirect .html to extensionless
  RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
  RewriteRule ^ %1 [R=301,L]

  ########################################
  # Map clean URL → .php or .html
  ########################################

  # Do not rewrite if file or directory already exists
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Internally process extensionless → .php
  RewriteCond %{REQUEST_FILENAME}.php -f
  RewriteRule ^(.+)$ $1.php [L]

  # Internally process extensionless → .html
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]

</IfModule>

########################################
# EXISTING HOTLINK PROTECTION (KEEPING YOUR RULES)
########################################
RewriteCond %{HTTP_REFERER} !^http://kristenbytes.com/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^http://kristenbytes.com$      [NC]
RewriteCond %{HTTP_REFERER} !^http://leads.kristenbytes.com/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^http://leads.kristenbytes.com$      [NC]
RewriteCond %{HTTP_REFERER} !^http://www.kristenbytes.com/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^http://www.kristenbytes.com$      [NC]
RewriteCond %{HTTP_REFERER} !^http://www.leads.kristenbytes.com/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^http://www.leads.kristenbytes.com$      [NC]
RewriteCond %{HTTP_REFERER} !^https://kristenbytes.com/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^https://kristenbytes.com$      [NC]
RewriteCond %{HTTP_REFERER} !^https://leads.kristenbytes.com/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^https://leads.kristenbytes.com$      [NC]
RewriteCond %{HTTP_REFERER} !^https://www.kristenbytes.com/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^https://www.kristenbytes.com$      [NC]
RewriteCond %{HTTP_REFERER} !^https://www.leads.kristenbytes.com/.*$      [NC]
RewriteCond %{HTTP_REFERER} !^https://www.leads.kristenbytes.com$      [NC]
RewriteRule .*\.(jpg|jpeg|gif|png|bmp)$ - [F,NC]

########################################
# CUSTOM 404 PAGE
########################################
# Make sure /404.html exists in public_html
ErrorDocument 404 /404.html

########################################
# CACHING (SPEED)
########################################
<IfModule mod_expires.c>
    ExpiresActive On

    # Images
    ExpiresByType image/jpeg  "access plus 1 month"
    ExpiresByType image/jpg   "access plus 1 month"
    ExpiresByType image/png   "access plus 1 month"
    ExpiresByType image/gif   "access plus 1 month"
    ExpiresByType image/webp  "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 year"

    # CSS & JS
    ExpiresByType text/css                    "access plus 7 days"
    ExpiresByType application/javascript      "access plus 7 days"
    ExpiresByType application/x-javascript    "access plus 7 days"

    # Fonts
    ExpiresByType font/ttf   "access plus 1 month"
    ExpiresByType font/otf   "access plus 1 month"
    ExpiresByType font/woff  "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 month"

    # HTML
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

########################################
# COMPRESSION (SPEED)
########################################
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
</IfModule>
